# ClauseLens — credential template.
# Copy this file to `.env` (which is gitignored — never commit real keys) and
# fill in ONE of the two auth options below. `src/config.py` loads it automatically.

# ─────────────────────────────────────────────────────────────────────────────
# OPTION A — Bedrock API key (a single long bearer token).
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

# OPTION B — IAM access key + secret (a PAIR). If you use this instead, delete
# the AWS_BEARER_TOKEN_BEDROCK line above and uncomment these two:
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# ─────────────────────────────────────────────────────────────────────────────

# Region where Anthropic Claude "Model access" is enabled in the Bedrock console.
AWS_DEFAULT_REGION=us-east-1
